# =============================================================
# WB Profit — пример .env переменных
# =============================================================
# Скопируй этот файл в .env (или загрузи через Vercel Dashboard →
# Project → Settings → Environment Variables) и заполни значения.
#
# Файл .env уже в .gitignore — никогда не коммить реальные ключи!
# =============================================================

# --- Supabase (обязательно) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Service role key — НИКОГДА не отдавать клиенту. Только в бэкенде.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
# Публичный ключ — отдаётся фронту через /api/config
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Совместимость со старыми SDK (можно дублировать значение PUBLISHABLE_KEY):
SUPABASE_ANON_KEY=

# --- Sentry (опционально, для error tracking) ---
# Получить: sentry.io → создать проект "wb-profit" → Settings → Client Keys (DSN)
SENTRY_DSN=

# --- Yandex.Metrika (опционально, для веб-аналитики) ---
# Получить: metrika.yandex.ru → создать счётчик → ID счётчика
YM_COUNTER_ID=

# --- ЮKassa (для будущей платёжной интеграции) ---
# yookassa.ru → регистрация мерчанта → Настройки → Интеграция
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# --- Telegram бот (для будущей активации расширения) ---
# @BotFather → /newbot → получить токен
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
